{
  "customizations": {
    "codespaces": {
      "openFiles": [
        "src/App.tsx",
        "README.md"
        //
      ]
    },
    "vscode": {
      "extensions": [
        "typescriptteam.native-preview",
        "dbaeumer.vscode-eslint",
        "zokugun.explicit-folding"
      ]
    }
  },
  "postCreateCommand": "npm install",
  "portsAttributes": {
    "5173": {
      "label": "Application",
      "onAutoForward": "openPreview"
    }
  }
}
