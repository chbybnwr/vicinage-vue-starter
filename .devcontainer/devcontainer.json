{
  "postCreateCommand": "npm install",
  "postAttachCommand": {
    "server": "npm run dev"
  },
  "portsAttributes": {
    "5173": {
      "label": "Application",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "src/App.tsx"
        //
      ]
    },
    "vscode": {
      "settings": {
        "workbench.secondarySideBar.defaultVisibility": "hidden"
      },
      "extensions": [
        "typescriptteam.native-preview",
        "dbaeumer.vscode-eslint",
        "zokugun.explicit-folding"
      ]
    }
  }
}
